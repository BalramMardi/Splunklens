{
  "name": "splunklens",
  "displayName": "Splunklens",
  "description": "Query splunk logs in plain English without leaving VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
  "viewsContainers": {
    "activitybar": [
      {
        "id": "splunklens",
        "title": "SplunkLens",
        "icon": "$(search)"
      }
    ]
  },
  "views": {
    "splunklens": [
      {
        "type": "webview",
        "id": "splunklens.view",
        "name": "SplunkLens"
      }
    ]
  }
},
 "scripts": {
  "vscode:prepublish": "npm run build",
  "build": "npm run build:webview && node esbuild.js",
  "build:webview": "cd webview && npm run build && xcopy /E /Y /I dist ..\\webview-dist",
  "watch": "node esbuild.js --watch",
  "compile": "node esbuild.js",
  "lint": "eslint src"
},
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
