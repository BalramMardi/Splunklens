{
  "name": "splunklens",
  "displayName": "Splunklens",
  "description": "Query splunk logs in plain English without leaving VS Code",
  "version": "1.0.0",
  "publisher": "balram-mardi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BalramMardi/Splunklens"
  },
  "icon": "assets/logo.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "splunklens",
          "title": "SplunkLens",
          "icon": "assets/monologo.png"
        }
      ]
    },
    "views": {
      "splunklens": [
        {
          "type": "webview",
          "id": "splunklens.view",
          "name": "SplunkLens"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:win && node esbuild.js",
    "build:mac": "npm run build:webview-mac && node esbuild.js",
    "build:win": "cd webview && npm run build && cd .. && xcopy /E /Y /I webview\\dist webview-dist",
    "build:webview-mac": "cd webview && npm run build && cd .. && rm -rf webview-dist && cp -r webview/dist webview-dist",
    "watch": "node esbuild.js --watch",
    "compile": "node esbuild.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-fetch": "^3.3.2"
  }
}
